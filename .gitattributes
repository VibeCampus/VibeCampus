# 自动检测文本文件并规范化换行符
* text=auto

# Java 源代码使用 LF (Unix 风格,跨平台兼容)
*.java text eol=lf

# JavaScript/TypeScript/Vue 前端文件使用 LF
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf

# 配置文件使用 LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.sql text eol=lf

# Shell 脚本和 Maven wrapper 使用 LF
*.sh text eol=lf
mvnw text eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 文档文件使用 LF
*.md text eol=lf
*.txt text eol=lf

# 图片等二进制文件不处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
