# 复制为 .env 后修改密码，切勿提交 .env
#   cp .env.example .env

MYSQL_ROOT_PASSWORD=请改为强密码
MYSQL_DATABASE=vibecampus
MYSQL_USER=vibecampus
MYSQL_PASSWORD=请改为强密码

# 后端 Spring Profile（生产环境）
SPRING_PROFILES_ACTIVE=prod

# 生产环境对外端口
WEB_PORT=80

# JWT 配置，密钥至少 32 字节
APP_JWT_SECRET=请改为至少32字节的随机密钥
APP_JWT_EXPIRATION_MINUTES=120
APP_JWT_ISSUER=vibecampus
